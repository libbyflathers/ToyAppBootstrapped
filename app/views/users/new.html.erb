<% content_for :title, "New user" %>

<div class="card">
  <div class="card-header"><i class="bi bi-pencil-square"></i> New User</div>
  <div class="card-body">
    <div class="card-group" id="users">
      <%= render "form", user: @user %>
    </div>
    <a href="<%= users_url %>" class="btn btn-danger float-end"><i class='bi bi-trash'></i> Cancel </a>
  </div>
</div>
